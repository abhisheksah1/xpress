# Required
MONGODB_URI=mongodb://127.0.0.1:27017/koselixpress
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Server
NODE_ENV=production
PORT=5000
API_VERSION=v1
CLIENT_URL=https://your-storefront-domain.com
ADMIN_URL=https://your-storefront-domain.com/admin

# Super admin (change before first deploy)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=use-a-strong-password
SUPER_ADMIN_PHONE=9800000000

# JWT lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (recommended for production uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=koselixpress

# Payment gateways (can also be configured in Admin → Settings)
KHALTI_SECRET_KEY=
KHALTI_PUBLIC_KEY=
KHALTI_VERIFY_URL=https://khalti.com/api/v2/epayment/lookup/
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=
ESEWA_VERIFY_URL=https://esewa.com.np/api/epay/transaction/status/
FONEPAY_MERCHANT_CODE=
FONEPAY_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# NPS OnePG — Visa / Mastercard (UAT / Sandbox)
# CheckOut credentials from Nepal Payment Solution
NPS_MERCHANT_ID=7534
NPS_MERCHANT_NAME=koseli
NPS_API_USERNAME=koseli
NPS_API_PASSWORD=Koseli@11
NPS_SECRET_KEY=KEX101
NPS_INSTRUMENT_CODE=
NPS_ENVIRONMENT=sandbox

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=KoseliXpress <noreply@yourdomain.com>

# Upload limits
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Rate limiting (production)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
RATE_LIMIT_AUTH_MAX=30

# Optional integrations
GOOGLE_PLACES_API_KEY=
