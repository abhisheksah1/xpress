# Required
MONGODB_URI=mongodb://127.0.0.1:27017/koselixpress
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Server
NODE_ENV=production
PORT=5000
API_VERSION=v1
CLIENT_URL=https://your-storefront-domain.com
ADMIN_URL=https://your-storefront-domain.com/admin
# FRONTEND_DIST=../frontend/dist
# CORS_ORIGINS=https://www.your-storefront-domain.com
# COOKIE_SAME_SITE=none
SERVER_URL=https://api.yourdomain.com

# Super admin
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=use-a-strong-password
SUPER_ADMIN_PHONE=9800000000

# JWT lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=koselixpress

# NPS OnePG (optional — also configurable in Admin)
NPS_MERCHANT_ID=
NPS_MERCHANT_NAME=
NPS_API_USERNAME=
NPS_API_PASSWORD=
NPS_SECRET_KEY=
NPS_ENVIRONMENT=sandbox

# Email (Brevo SMTP)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SENDER_EMAIL=you@verified-sender.com
BREVO_SENDER_NAME=KoseliXpress

# Upload limits
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
RATE_LIMIT_AUTH_MAX=30
